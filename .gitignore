# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# claude local settings (contains secrets)
.claude/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.*
.env-val
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# audit/test screenshots (local only)
audit-*.png
cookie-*.png
i18n-*.png
prod-*.png
test-final-*.png
overlay-*.png
upload-*.png

# scratch / throwaway scripts (may contain secrets — never commit)
scratch/
scratch_temp_*

# playwright MCP local data
.playwright-mcp/

.vercel
.env*.local
