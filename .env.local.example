# ==============================================================================
# Armocromia MVP — Variabili d'Ambiente
# ==============================================================================
# Copia questo file come .env.local e popola i valori:
#   cp .env.local.example .env.local
#
# IMPORTANTE: .env.local è gitignored e non va mai committato.
# ==============================================================================

# --- Supabase (richiesto) ---
# URL del progetto Supabase (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable Key (nuova nomenclatura, sostituisce anon key)
# Dashboard > Settings > API Keys > Publishable Key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret Key (server-side only, per operazioni admin)
# Dashboard > Settings > API Keys > Secret Key
# SUPABASE_SECRET_KEY=

# --- fal.ai (richiesto per generazione immagini) ---
# API Key fal.ai — https://fal.ai/dashboard/keys
FAL_KEY=

# --- Stripe (sarà richiesto in fase pagamento) ---
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- OpenAI (sarà richiesto per classificazione Vision) ---
# OPENAI_API_KEY=

# --- Resend (sarà richiesto per email transazionali) ---
# RESEND_API_KEY=

# --- App Config ---
# URL base dell'app (per link in email, redirect, ecc.)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Analytics 4 (opzionale, gated dal consenso cookie) ---
# Measurement ID nel formato G-XXXXXXXXXX
# Crea una proprietà GA4 su https://analytics.google.com →
# Admin → Data Streams → Web → copia il Measurement ID.
# Se non valorizzato, il tracking è completamente disattivato (no-op).
# Il caricamento di gtag.js è gated da Google Consent Mode v2 (default 'denied'):
# le hit partono SOLO dopo che l'utente accetta i cookie analitici.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
